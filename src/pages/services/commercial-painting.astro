---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import OfferBand from '../../components/OfferBand.astro';
import LeadCaptureForm from '../../components/LeadCaptureForm.astro';
---

<BaseLayout
  title="Commercial Painting Contractor Dixon, CA | Dixon Painting Co."
  description="Reliable commercial painting services for businesses in Dixon, CA and nearby areas. Minimal disruption, quality results. Call (916) 612-2126."
>
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <div class="container">
      <ol class="breadcrumb__list" role="list">
        <li><a href="/">Home</a></li>
        <li aria-hidden="true">›</li>
        <li><a href="/services">Services</a></li>
        <li aria-hidden="true">›</li>
        <li aria-current="page">Commercial Painting</li>
      </ol>
    </div>
  </nav>

  <Hero
    headline="Commercial Painting in Dixon, CA — Professional Results, Minimal Disruption"
    subheadline="We work around your schedule so your business doesn't skip a beat."
    body="First impressions matter. Whether it's a retail space, office, or multi-unit property, Dixon Painting Co. delivers professional commercial painting with the reliability your business depends on. We coordinate around your hours — early mornings, evenings, weekends — and we're experienced working in occupied spaces. Clean, efficient, and done when we say it will be."
    primaryCtaText="Request a Commercial Painting Estimate"
    primaryCtaHref="/contact"
    urgencyCtaText="Call (916) 612-2126"
    urgencyCtaHref="tel:+19166122126"
    imageSrc="/assets/images/service-commercial-painting.webp"
    imageAlt="Commercial painting by Dixon Painting Co."
    showForm={false}
  />

  <section class="service-detail">
    <div class="container service-detail__inner">
      <div class="service-detail__content">
        <h2>Commercial Painting Services We Offer</h2>
        <ul class="service-detail__list">
          <li>Office and corporate interior painting</li>
          <li>Retail store and showroom painting</li>
          <li>Multi-unit residential and apartment complex painting</li>
          <li>Restaurant and hospitality interior/exterior work</li>
          <li>Warehouse and industrial space painting</li>
          <li>Exterior commercial building painting and touch-up</li>
          <li>Flexible scheduling — nights, weekends, and phased work</li>
        </ul>
        <div class="service-detail__trust">
          <span>Licensed &amp; Insured</span>
          <span>Flexible Scheduling</span>
          <span>Free Estimate</span>
        </div>
      </div>
      <div class="service-detail__cta">
        <LeadCaptureForm headingText="Request a Commercial Estimate" formId="commercial-estimate" />
      </div>
    </div>
  </section>

  <OfferBand
    headline="Free Commercial Painting Estimate — No Obligation"
    subheadline="We'll assess your space, understand your timeline, and give you a clear proposal before any work begins."
    primaryCtaText="Schedule My Free Estimate"
  />

  <script type="application/ld+json">
    {JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.dixonpaintingco.com/" },
        { "@type": "ListItem", "position": 2, "name": "Services", "item": "https://www.dixonpaintingco.com/services" },
        { "@type": "ListItem", "position": 3, "name": "Commercial Painting", "item": "https://www.dixonpaintingco.com/services/commercial-painting" }
      ]
    })}
  </script>
</BaseLayout>

<style>
  .breadcrumb { background: var(--color-neutral-50); border-bottom: 1px solid var(--color-neutral-200); padding: 0.75rem 1.5rem; }
  .breadcrumb__list { display: flex; flex-wrap: wrap; gap: 0.5rem; align-items: center; list-style: none; margin: 0; padding: 0; font-size: 0.875rem; color: var(--color-text-muted); }
  .breadcrumb__list a { color: var(--color-primary); text-decoration: none; }
  .breadcrumb__list a:hover { color: var(--color-accent); }
  .service-detail { padding: 5rem 1.5rem; background: #fff; }
  .service-detail__inner { display: grid; grid-template-columns: 1fr 400px; gap: 4rem; align-items: start; }
  .service-detail__content h2 { font-family: var(--font-display); font-size: clamp(1.5rem, 3vw, 2rem); color: var(--color-primary); margin-bottom: 1.5rem; }
  .service-detail__list { list-style: none; margin: 0 0 2rem; padding: 0; display: flex; flex-direction: column; gap: 0.75rem; }
  .service-detail__list li { display: flex; align-items: flex-start; gap: 0.75rem; color: var(--color-text); line-height: 1.5; font-size: 0.975rem; }
  .service-detail__list li::before { content: '✓'; color: var(--color-accent); font-weight: 700; flex-shrink: 0; margin-top: 1px; }
  .service-detail__trust { display: flex; flex-wrap: wrap; gap: 0.75rem; }
  .service-detail__trust span { background: var(--color-neutral-50); border: 1px solid var(--color-neutral-200); padding: 0.35rem 0.875rem; border-radius: 4px; font-size: 0.8rem; font-weight: 600; color: var(--color-primary); }
  @media (max-width: 900px) { .service-detail__inner { grid-template-columns: 1fr; } }
</style>
