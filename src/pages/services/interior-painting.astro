---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import OfferBand from '../../components/OfferBand.astro';
import LeadCaptureForm from '../../components/LeadCaptureForm.astro';
---

<BaseLayout
  title="Interior Painting in Dixon, CA | Dixon Painting Co."
  description="Professional interior painting services in Dixon, CA. Clean, precise, and on schedule. Call (916) 612-2126 for a free estimate from Dixon Painting Co."
>
  <Hero
    headline="Interior Painting in Dixon, CA — Clean Work, No Mess, Beautiful Finish"
    subheadline="We protect your floors, furniture, and trim — and leave your rooms looking like new."
    body="Interior painting is more than picking a color. It's proper prep, clean lines, and a finish that doesn't show brush marks six months later. Dixon Painting Co. handles everything from walls and ceilings to trim and accent walls — in any room, any size. We work cleanly, move carefully, and leave your home the way we found it (except with a fresh coat of paint)."
    primaryCtaText="Get a Free Interior Painting Estimate"
    primaryCtaHref="/contact"
    urgencyCtaText="Call (916) 612-2126"
    urgencyCtaHref="tel:+19166122126"
    imageSrc="/assets/images/service-interior-painting.webp"
    imageAlt="Interior painting by Dixon Painting Co."
    showForm={false}
  />

  <!-- What's included -->
  <section class="service-detail">
    <div class="container service-detail__inner">
      <div class="service-detail__content">
        <h2>What's Included in Our Interior Painting Service</h2>
        <ul class="service-detail__list">
          <li>Full furniture moving and protection (drop cloths + plastic sheeting)</li>
          <li>Surface prep: patching holes, sanding rough spots, cleaning walls</li>
          <li>Premium primer application where needed</li>
          <li>2 finish coats with professional-grade Sherwin-Williams or Benjamin Moore paint</li>
          <li>Clean lines at trim, ceiling, and doorways</li>
          <li>Complete cleanup and furniture repositioning</li>
          <li>Final walkthrough — we don't leave until you're satisfied</li>
        </ul>
        <div class="service-detail__trust">
          <span>Licensed &amp; Insured</span>
          <span>Free Color Consultation</span>
          <span>Free Estimate</span>
        </div>
      </div>
      <div class="service-detail__cta">
        <LeadCaptureForm headingText="Get a Free Interior Painting Estimate" formId="interior-estimate" />
      </div>
    </div>
  </section>

  <OfferBand
    headline="Free Color Consultation with Every Interior Estimate"
    subheadline="Not sure what color to choose? We'll help you find the perfect shade before we pick up a brush. No obligation."
    primaryCtaText="Schedule My Free Estimate"
  />

  <!-- Breadcrumb schema -->
  <script type="application/ld+json">
    {JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.dixonpaintingco.com/" },
        { "@type": "ListItem", "position": 2, "name": "Services", "item": "https://www.dixonpaintingco.com/services" },
        { "@type": "ListItem", "position": 3, "name": "Interior Painting", "item": "https://www.dixonpaintingco.com/services/interior-painting" }
      ]
    })}
  </script>
</BaseLayout>

<style>
  .service-detail { padding: 5rem 1.5rem; background: #fff; }
  .service-detail__inner { display: grid; grid-template-columns: 1fr 400px; gap: 4rem; align-items: start; }
  .service-detail__content h2 {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2rem);
    color: var(--color-primary);
    margin-bottom: 1.5rem;
  }
  .service-detail__list {
    list-style: none;
    margin: 0 0 2rem;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .service-detail__list li {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    color: var(--color-text);
    line-height: 1.5;
    font-size: 0.975rem;
  }
  .service-detail__list li::before {
    content: '✓';
    color: var(--color-accent);
    font-weight: 700;
    flex-shrink: 0;
    margin-top: 1px;
  }
  .service-detail__trust {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  .service-detail__trust span {
    background: var(--color-neutral-50);
    border: 1px solid var(--color-neutral-200);
    padding: 0.35rem 0.875rem;
    border-radius: 4px;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-primary);
  }
  @media (max-width: 900px) {
    .service-detail__inner { grid-template-columns: 1fr; }
  }
</style>

<nav class="breadcrumb" aria-label="Breadcrumb">
  <div class="container">
    <ol class="breadcrumb__list" role="list">
      <li><a href="/">Home</a></li>
      <li aria-hidden="true">›</li>
      <li><a href="/services">Services</a></li>
      <li aria-hidden="true">›</li>
      <li aria-current="page">Interior Painting</li>
    </ol>
  </div>
</nav>

<style>
  .breadcrumb { background: var(--color-neutral-50); border-bottom: 1px solid var(--color-neutral-200); padding: 0.75rem 1.5rem; }
  .breadcrumb__list { display: flex; flex-wrap: wrap; gap: 0.5rem; align-items: center; list-style: none; margin: 0; padding: 0; font-size: 0.875rem; color: var(--color-text-muted); }
  .breadcrumb__list a { color: var(--color-primary); text-decoration: none; }
  .breadcrumb__list a:hover { color: var(--color-accent); }
</style>
