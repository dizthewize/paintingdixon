---
interface Props {
  currentPath: string;
}
const { currentPath } = Astro.props;

const navLinks = [
  { label: 'Gallery', href: '/gallery' },
  { label: 'Service Areas', href: '/service-areas' },
  { label: 'About', href: '/about' },
  { label: 'Blog', href: '/blog' },
];

const serviceLinks = [
  { label: 'Interior Painting', href: '/services/interior-painting' },
  { label: 'Exterior Painting', href: '/services/exterior-painting' },
  { label: 'Cabinet Painting', href: '/services/cabinet-painting' },
  { label: 'Commercial Painting', href: '/services/commercial-painting' },
];
---

<header class="site-header" role="banner" id="site-header">
  <div class="container site-header__inner">
    <!-- Logo -->
    <a href="/" class="site-header__logo" aria-label="Dixon Painting Co. — Home">
      <span class="site-header__logo-text">Dixon Painting Co.</span>
    </a>

    <!-- Desktop Nav -->
    <nav class="site-header__nav" aria-label="Main navigation">
      <ul class="site-header__nav-list" role="list">
        <!-- Services Dropdown -->
        <li class="site-header__nav-item site-header__dropdown">
          <button
            class="site-header__nav-link site-header__dropdown-toggle"
            aria-haspopup="true"
            aria-expanded="false"
            id="services-dropdown-btn"
          >
            Services
            <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="m6 9 6 6 6-6"/>
            </svg>
          </button>
          <ul class="site-header__dropdown-menu" role="menu" id="services-dropdown-menu">
            {serviceLinks.map(link => (
              <li role="none">
                <a
                  href={link.href}
                  role="menuitem"
                  class="site-header__dropdown-link"
                  aria-current={currentPath === link.href ? 'page' : undefined}
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </li>

        {navLinks.map(link => (
          <li class="site-header__nav-item">
            <a
              href={link.href}
              class="site-header__nav-link"
              aria-current={currentPath === link.href ? 'page' : undefined}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <!-- Right side: phone + CTA -->
    <div class="site-header__actions">
      <a
        href="tel:+19166122126"
        class="site-header__phone"
        aria-label="Call Dixon Painting Co. at (916) 612-2126"
      >
        (916) 612-2126
      </a>
      <a href="/contact" class="site-header__cta">
        Get Free Estimate
      </a>
    </div>

    <!-- Hamburger (mobile) -->
    <button
      class="site-header__hamburger"
      aria-label="Open navigation menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
      id="hamburger-btn"
    >
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div class="site-header__mobile-menu" id="mobile-menu" hidden>
    <nav aria-label="Mobile navigation">
      <ul role="list">
        <li><a href="/services" class="site-header__mobile-link">Services</a></li>
        {serviceLinks.map(link => (
          <li>
            <a href={link.href} class="site-header__mobile-link site-header__mobile-sublink">
              {link.label}
            </a>
          </li>
        ))}
        {navLinks.map(link => (
          <li>
            <a href={link.href} class="site-header__mobile-link">
              {link.label}
            </a>
          </li>
        ))}
        <li>
          <a href="tel:+19166122126" class="site-header__mobile-link site-header__mobile-phone" aria-label="Call Dixon Painting Co. at (916) 612-2126">
            📞 (916) 612-2126
          </a>
        </li>
        <li>
          <a href="/contact" class="site-header__mobile-cta">Get Free Estimate</a>
        </li>
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 40;
    height: 80px;
    background: var(--color-primary);
    transition: height 0.2s ease, background 0.2s ease, box-shadow 0.2s ease;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .site-header.scrolled {
    height: 60px;
    background: #fff;
    box-shadow: 0 1px 0 var(--color-neutral-200);
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    gap: 2rem;
    height: 100%;
  }

  .site-header__logo {
    flex-shrink: 0;
    text-decoration: none;
  }

  .site-header__logo-text {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    color: #fff;
    transition: color 0.2s;
  }

  .site-header.scrolled .site-header__logo-text {
    color: var(--color-primary);
  }

  .site-header__nav {
    flex: 1;
  }

  .site-header__nav-list {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .site-header__nav-link {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.5rem 0.75rem;
    color: rgba(255, 255, 255, 0.9);
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
    background: none;
    border: none;
    cursor: pointer;
    border-radius: 4px;
    transition: color 0.15s, background 0.15s;
    white-space: nowrap;
    font-family: var(--font-body);
  }

  .site-header.scrolled .site-header__nav-link {
    color: var(--color-text);
  }

  .site-header__nav-link:hover,
  .site-header__nav-link[aria-current="page"] {
    background: rgba(255, 255, 255, 0.1);
  }

  .site-header.scrolled .site-header__nav-link:hover {
    background: var(--color-neutral-100);
  }

  /* Dropdown */
  .site-header__dropdown {
    position: relative;
  }

  .site-header__dropdown-menu {
    display: none;
    position: absolute;
    top: calc(100% + 0.5rem);
    left: 0;
    min-width: 220px;
    background: #fff;
    border: 1px solid var(--color-neutral-200);
    border-radius: 6px;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
    list-style: none;
    margin: 0;
    padding: 0.5rem 0;
    z-index: 50;
  }

  .site-header__dropdown-menu.open {
    display: block;
  }

  .site-header__dropdown-link {
    display: block;
    padding: 0.5rem 1rem;
    font-size: 0.875rem;
    color: var(--color-text);
    text-decoration: none;
    transition: background 0.1s;
  }

  .site-header__dropdown-link:hover {
    background: var(--color-neutral-50);
    color: var(--color-accent);
  }

  .site-header__actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  .site-header__phone {
    color: var(--color-accent);
    font-weight: 700;
    font-size: 0.95rem;
    text-decoration: none;
    transition: color 0.2s;
    white-space: nowrap;
  }

  .site-header.scrolled .site-header__phone {
    color: var(--color-primary);
  }

  .site-header__cta {
    background: var(--color-accent);
    color: #fff;
    padding: 0.6rem 1.25rem;
    border-radius: 4px;
    font-weight: 700;
    font-size: 0.875rem;
    text-decoration: none;
    white-space: nowrap;
    transition: background 0.15s ease;
  }

  .site-header__cta:hover {
    background: var(--color-accent-dark);
  }

  .site-header__hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    margin-left: auto;
  }

  .site-header__hamburger span {
    display: block;
    width: 24px;
    height: 2px;
    background: #fff;
    border-radius: 2px;
    transition: background 0.2s;
  }

  .site-header.scrolled .site-header__hamburger span {
    background: var(--color-primary);
  }

  /* Mobile menu */
  .site-header__mobile-menu {
    background: var(--color-primary);
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .site-header__mobile-menu ul {
    list-style: none;
    margin: 0;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .site-header__mobile-link {
    display: block;
    padding: 0.75rem 1rem;
    color: rgba(255, 255, 255, 0.9);
    font-weight: 600;
    text-decoration: none;
    border-radius: 4px;
    transition: background 0.15s;
  }

  .site-header__mobile-link:hover {
    background: rgba(255, 255, 255, 0.1);
  }

  .site-header__mobile-sublink {
    padding-left: 2rem;
    font-size: 0.875rem;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.75);
  }

  .site-header__mobile-phone {
    color: var(--color-accent);
    font-weight: 700;
  }

  .site-header__mobile-cta {
    display: block;
    background: var(--color-accent);
    color: #fff;
    padding: 0.875rem 1rem;
    border-radius: 4px;
    font-weight: 700;
    text-align: center;
    text-decoration: none;
    margin-top: 0.5rem;
    transition: background 0.15s;
  }

  .site-header__mobile-cta:hover {
    background: var(--color-accent-dark);
  }

  @media (max-width: 1024px) {
    .site-header__nav { display: none; }
    .site-header__phone { display: none; }
    .site-header__cta { display: none; }
    .site-header__hamburger { display: flex; }
    .site-header { height: 60px !important; }
  }
</style>

<script>
  // Header scroll shrink
  const header = document.getElementById('site-header');
  const sentinel = document.getElementById('header-sentinel');

  if (header && sentinel) {
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (!entry.isIntersecting) {
          header.classList.add('scrolled');
        } else {
          header.classList.remove('scrolled');
        }
      },
      { threshold: 0 }
    );
    observer.observe(sentinel);
  }

  // Mobile menu toggle
  const hamburger = document.getElementById('hamburger-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  if (hamburger && mobileMenu) {
    hamburger.addEventListener('click', () => {
      const isOpen = hamburger.getAttribute('aria-expanded') === 'true';
      hamburger.setAttribute('aria-expanded', String(!isOpen));
      mobileMenu.hidden = isOpen;
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !mobileMenu.hidden) {
        mobileMenu.hidden = true;
        hamburger.setAttribute('aria-expanded', 'false');
        hamburger.focus();
      }
    });
  }

  // Services dropdown toggle
  const dropdownBtn = document.getElementById('services-dropdown-btn');
  const dropdownMenu = document.getElementById('services-dropdown-menu');

  if (dropdownBtn && dropdownMenu) {
    dropdownBtn.addEventListener('click', () => {
      const isOpen = dropdownBtn.getAttribute('aria-expanded') === 'true';
      dropdownBtn.setAttribute('aria-expanded', String(!isOpen));
      dropdownMenu.classList.toggle('open', !isOpen);
    });

    document.addEventListener('click', (e) => {
      if (!dropdownBtn.contains(e.target as Node)) {
        dropdownBtn.setAttribute('aria-expanded', 'false');
        dropdownMenu.classList.remove('open');
      }
    });
  }
</script>
