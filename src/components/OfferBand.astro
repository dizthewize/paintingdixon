---
interface Props {
  badgeText?: string;
  headline?: string;
  subheadline?: string;
  primaryCtaText?: string;
  primaryCtaHref?: string;
}

const {
  badgeText = 'FREE COLOR CONSULTATION INCLUDED',
  headline = 'Not Sure What Color to Choose? We\'ll Help — Free.',
  subheadline = "Every estimate from Dixon Painting Co. includes a complimentary color consultation. We'll walk through your space, understand your vision, and help you find the perfect shade before a single brush stroke.",
  primaryCtaText = 'Get My Free Estimate + Color Consult',
  primaryCtaHref = '/contact',
} = Astro.props;
---

<section class="offer-band" aria-labelledby="offer-band-heading">
  <div class="container offer-band__inner">
    <span class="offer-band__badge">{badgeText}</span>
    <h2 class="offer-band__headline" id="offer-band-heading">{headline}</h2>
    <p class="offer-band__sub">{subheadline}</p>
    <div class="offer-band__cta-group">
      <a href={primaryCtaHref} class="offer-band__cta-primary">
        {primaryCtaText}
      </a>
      <a
        href="tel:+19166122126"
        class="offer-band__cta-phone"
        aria-label="Call Dixon Painting Co. at (916) 612-2126"
      >
        Or Call (916) 612-2126
      </a>
    </div>
  </div>
</section>

<style>
  .offer-band {
    background: var(--color-primary);
    padding: 5rem 1.5rem;
    text-align: center;
  }

  .offer-band__inner {
    max-width: 780px;
  }

  .offer-band__badge {
    display: inline-block;
    background: var(--color-accent);
    color: #fff;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.35rem 1rem;
    border-radius: 2px;
    margin-bottom: 1.25rem;
  }

  .offer-band__headline {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    color: #fff;
    margin-bottom: 0.75rem;
  }

  .offer-band__sub {
    color: rgba(255, 255, 255, 0.8);
    font-size: 1.05rem;
    margin-bottom: 2rem;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.65;
  }

  .offer-band__cta-group {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .offer-band__cta-primary {
    background: var(--color-accent);
    color: #fff;
    padding: 1rem 2.25rem;
    border-radius: 4px;
    font-weight: 700;
    text-decoration: none;
    transition: background 0.15s;
    font-size: 1rem;
  }

  .offer-band__cta-primary:hover {
    background: var(--color-accent-dark);
  }

  .offer-band__cta-phone {
    border: 2px solid rgba(255, 255, 255, 0.5);
    color: #fff;
    padding: 1rem 2.25rem;
    border-radius: 4px;
    font-weight: 600;
    text-decoration: none;
    transition: border-color 0.15s;
    font-size: 1rem;
  }

  .offer-band__cta-phone:hover {
    border-color: #fff;
  }

  @media (max-width: 480px) {
    .offer-band__cta-group {
      flex-direction: column;
      align-items: center;
    }

    .offer-band__cta-primary,
    .offer-band__cta-phone {
      width: 100%;
      text-align: center;
    }
  }
</style>
